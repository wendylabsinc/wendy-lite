menu "Wendy MCU Firmware Configuration"

    config WENDY_FIRMWARE_VERSION_MAJOR
        int "Firmware version major"
        default 0

    config WENDY_FIRMWARE_VERSION_MINOR
        int "Firmware version minor"
        default 1

    config WENDY_FIRMWARE_VERSION_PATCH
        int "Firmware version patch"
        default 0

    menu "WASM Runtime"
        config WENDY_WASM_STACK_SIZE
            int "WASM stack size (bytes)"
            default 32768
            help
                Stack size for the WASM runtime execution environment.

        config WENDY_WASM_HEAP_SIZE
            int "WASM heap size (bytes)"
            default 32768
            help
                Heap size available to WASM applications (inside WAMR pool).

        config WENDY_WASM_POOL_SIZE
            int "WAMR memory pool size (bytes)"
            default 180224
            help
                Total pre-allocated pool for the WAMR runtime. This is
                grabbed early in boot before WiFi/BLE consume RAM.
                Must fit linear memory + heap + stack + WAMR overhead.
                ESP32-C6: 176 KB (294 KB total, ~114 KB left for WiFi/BLE).

        config WENDY_WASM_USE_PSRAM
            bool "Allocate WASM heap from PSRAM"
            default y if SPIRAM
            help
                When PSRAM is available, allocate the WASM heap from
                external memory to preserve internal SRAM.
    endmenu

    menu "Hardware Abstraction Layer"
        config WENDY_HAL_GPIO
            bool "Enable GPIO HAL"
            default y

        config WENDY_HAL_I2C
            bool "Enable I2C HAL"
            default y

        config WENDY_HAL_I2C_PORT
            int "Default I2C port number"
            depends on WENDY_HAL_I2C
            default 0
            range 0 1

        config WENDY_HAL_I2C_SDA
            int "Default I2C SDA pin"
            depends on WENDY_HAL_I2C
            default 8

        config WENDY_HAL_I2C_SCL
            int "Default I2C SCL pin"
            depends on WENDY_HAL_I2C
            default 9

        config WENDY_HAL_I2C_FREQ_HZ
            int "Default I2C frequency (Hz)"
            depends on WENDY_HAL_I2C
            default 100000

        config WENDY_HAL_TIMER
            bool "Enable Timer HAL"
            default y

        config WENDY_HAL_NEOPIXEL
            bool "Enable NeoPixel (WS2812) HAL"
            default y

        config WENDY_HAL_RMT
            bool "Enable RMT timing-buffer HAL"
            default y
            help
                Raw RMT peripheral access for precise timing waveforms
                (WS2812, IR, etc.) from WASM apps.

    endmenu

    menu "Callback Subsystem"
        config WENDY_CALLBACK
            bool "Enable callback dispatch system"
            default y
            help
                Enable the FreeRTOS queue-based callback dispatch system.
                Required for timer callbacks, GPIO interrupts, BLE events,
                and other async operations from WASM.
    endmenu

    menu "System Functions"
        config WENDY_SYS
            bool "Enable system host functions"
            default y
            help
                System functions: uptime, reboot, firmware version,
                device ID, sleep, yield.
    endmenu

    menu "Storage (NVS)"
        config WENDY_STORAGE
            bool "Enable NVS storage host functions"
            default y
            help
                NVS-backed key/value storage accessible from WASM apps.
    endmenu

    menu "UART"
        config WENDY_UART
            bool "Enable UART host functions"
            default y
            help
                UART serial port access from WASM apps.
    endmenu

    menu "SPI"
        config WENDY_SPI
            bool "Enable SPI host functions"
            default y
            help
                SPI master bus access from WASM apps.
    endmenu

    menu "OpenTelemetry"
        config WENDY_OTEL
            bool "Enable OpenTelemetry host functions"
            default y
            help
                In-memory logging, metrics, and tracing from WASM apps.
    endmenu

    menu "WASI Shim"
        config WENDY_WASI_SHIM
            bool "Enable WASI Preview 1 shim"
            default y
            help
                Minimal WASI Preview 1 implementation for compatibility
                with wasm32-wasip1 binaries (Rust, etc.).
    endmenu

    menu "BLE"
        config WENDY_BLE
            bool "Enable BLE host functions"
            default n
            depends on BT_ENABLED && BT_NIMBLE_ENABLED
            help
                BLE GAP and GATT functions using NimBLE.
    endmenu

    menu "BLE Provisioning"
        config WENDY_BLE_PROV
            bool "Enable BLE WiFi provisioning and discovery"
            default y
            depends on BT_ENABLED && BT_NIMBLE_ENABLED
            help
                Advertise via BLE as "Wendy-XXXX" and expose a GATT service
                that allows clients to write WiFi credentials.  Credentials
                are stored in NVS and survive reboots.

        config WENDY_BLE_PROV_DEVICE_PREFIX
            string "BLE device name prefix"
            depends on WENDY_BLE_PROV
            default "Wendy"
            help
                The BLE advertising name will be "<prefix>-XXXX" where XXXX
                is derived from the last 2 bytes of the BT MAC address.
    endmenu

    menu "Cloud Provisioning"
        config WENDY_CLOUD_PROV
            bool "Enable cloud certificate provisioning via BLE"
            default n
            depends on WENDY_BLE_PROV
            help
                Expose a BLE GATT service for provisioning a device certificate,
                private key, and cloud endpoint URL. Once committed, the device
                is locked and cannot be re-provisioned without erasing NVS.

        config WENDY_CLOUD_PROV_CERT_BUF_SIZE
            int "Certificate receive buffer size (bytes)"
            depends on WENDY_CLOUD_PROV
            default 2048
            help
                Maximum size for the client certificate PEM received via BLE.

        config WENDY_CLOUD_PROV_KEY_BUF_SIZE
            int "Private key receive buffer size (bytes)"
            depends on WENDY_CLOUD_PROV
            default 2048
            help
                Maximum size for the private key PEM received via BLE.

        config WENDY_CLOUD_PROV_URL_BUF_SIZE
            int "Cloud URL buffer size (bytes)"
            depends on WENDY_CLOUD_PROV
            default 256
            help
                Maximum length of the cloud endpoint URL.
    endmenu

    menu "Networking (App-facing)"
        config WENDY_NET
            bool "Enable networking host functions"
            default n
            help
                WiFi control, BSD sockets, DNS, and TLS from WASM apps.
    endmenu

    menu "App USB"
        config WENDY_APP_USB
            bool "Enable app-facing USB functions"
            default n
            help
                USB CDC and HID access from WASM apps.
                Only functional on ESP32-S2/S3 with USB OTG.
    endmenu

    menu "WiFi Communication"
        config WENDY_WIFI_ENABLED
            bool "Enable WiFi transport"
            default n
            help
                Connect to WiFi, register this device via mDNS,
                and listen for UDP reload broadcasts that carry the
                host's HTTP address for WASM binary downloads.

        config WENDY_WIFI_SSID
            string "WiFi SSID"
            depends on WENDY_WIFI_ENABLED
            default "Wokwi-GUEST"

        config WENDY_WIFI_PASSWORD
            string "WiFi password"
            depends on WENDY_WIFI_ENABLED
            default ""

        config WENDY_WIFI_UDP_PORT
            int "UDP reload listener port"
            depends on WENDY_WIFI_ENABLED
            default 4210

    endmenu

    menu "USB Communication"
        config WENDY_USB_CDC_ENABLED
            bool "Enable USB CDC protocol"
            default y

        config WENDY_USB_PROTOCOL_VERSION
            int "USB protocol version"
            default 1

        config WENDY_USB_CHUNK_SIZE
            int "Upload chunk size (bytes)"
            default 4096
    endmenu

endmenu
