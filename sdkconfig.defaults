# Target: ESP32-C6
CONFIG_IDF_TARGET="esp32c6"

# Flash size (8MB to accommodate dual WASM slots)
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y

# Partition table - custom for dual WASM slots
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"

# WAMR configuration
CONFIG_WENDY_WASM_STACK_SIZE=8192
CONFIG_WENDY_WASM_HEAP_SIZE=8192
CONFIG_WENDY_WASM_POOL_SIZE=229376

# Disable WAMR pthread (causes assert in FreeRTOS tasks)
# CONFIG_WAMR_ENABLE_LIB_PTHREAD is not set
# CONFIG_WAMR_ENABLE_SHARED_MEMORY is not set

# Disable WAMR built-in WASI (we provide our own shim)
# CONFIG_WAMR_ENABLE_LIBC_WASI is not set

# Wendy HAL defaults
CONFIG_WENDY_HAL_GPIO=y
CONFIG_WENDY_HAL_I2C=y
CONFIG_WENDY_HAL_TIMER=y
CONFIG_WENDY_HAL_NEOPIXEL=y

# Callback subsystem
CONFIG_WENDY_CALLBACK=y

# System functions
CONFIG_WENDY_SYS=y

# NVS storage
CONFIG_WENDY_STORAGE=y

# UART
CONFIG_WENDY_UART=y

# SPI
CONFIG_WENDY_SPI=y

# OpenTelemetry
CONFIG_WENDY_OTEL=y

# WASI shim
CONFIG_WENDY_WASI_SHIM=y

# BLE stack (NimBLE)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_MAX_CONNECTIONS=2

# BLE provisioning and discovery
CONFIG_WENDY_BLE_PROV=y

# Cloud provisioning (device certificates via BLE)
CONFIG_WENDY_CLOUD_PROV=y

# App-facing BLE host functions disabled by default
# CONFIG_WENDY_BLE is not set

# App-facing networking (sockets, DNS, TLS)
CONFIG_WENDY_NET=y

# App-facing USB disabled by default (no OTG on C6)
# CONFIG_WENDY_APP_USB is not set

# USB CDC not available on C6 (no native USB OTG)
# CONFIG_WENDY_USB_CDC_ENABLED is not set

# WiFi transport for WASM download
CONFIG_WENDY_WIFI_ENABLED=y
CONFIG_WENDY_WIFI_SSID=""
CONFIG_WENDY_WIFI_PASSWORD=""

# Console over UART (compatible with Wokwi and most debug setups)
CONFIG_ESP_CONSOLE_UART_DEFAULT=y

# --- Memory optimizations ---

# 1. Size-optimized build (-Os instead of -Og)
CONFIG_COMPILER_OPTIMIZATION_SIZE=y
CONFIG_COMPILER_OPTIMIZATION_ASSERTIONS_SILENT=y
CONFIG_COMPILER_OPTIMIZATION_ASSERTION_LEVEL=1

# 2. Disable stack overflow canary (saves RAM per task)
CONFIG_FREERTOS_CHECK_STACKOVERFLOW_NONE=y

# Move WiFi/PHY hot paths from IRAM to flash (frees ~15-25 KB DIRAM)
CONFIG_ESP_WIFI_IRAM_OPT=n
CONFIG_ESP_WIFI_EXTRA_IRAM_OPT=n
CONFIG_ESP_WIFI_RX_IRAM_OPT=n
CONFIG_ESP_WIFI_SLP_IRAM_OPT=n
CONFIG_ESP_PHY_IRAM_OPT=n

# 3. Tune NimBLE buffer pools (sized for max 2 connections)
CONFIG_BT_NIMBLE_MSYS_1_BLOCK_COUNT=12
CONFIG_BT_NIMBLE_MSYS_2_BLOCK_COUNT=12
CONFIG_BT_NIMBLE_TRANSPORT_ACL_FROM_LL_COUNT=8
CONFIG_BT_NIMBLE_TRANSPORT_EVT_COUNT=12
CONFIG_BT_NIMBLE_TRANSPORT_EVT_DISCARD_COUNT=4
